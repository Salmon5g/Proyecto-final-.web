# ─────────────────────────────────────────────
# BACKEND
# ─────────────────────────────────────────────

# Cadena de conexión completa a PostgreSQL
# Local:      postgresql://usuario:password@localhost:5432/nombre_bd
# Railway:    se copia desde el panel de Railway → tu base de datos → Connect
DATABASE_URL=postgresql://usuario:password@localhost:5432/estacionamiento_db

# Clave secreta para firmar los tokens JWT (autenticación)
# Usa una cadena larga y aleatoria — nunca la compartas
JWT_SECRET=cambiar_por_secreto_largo_aleatorio

# Puerto en que corre el servidor Express
# Railway lo asigna automáticamente, no necesitas cambiarlo en producción
PORT=3000

# Entorno de ejecución: development | production | test
NODE_ENV=development

# URL del frontend permitida para hacer peticiones al backend (CORS)
# Local:      http://localhost:5173
# Producción: https://tu-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─────────────────────────────────────────────
# FRONTEND (Vite)
# ─────────────────────────────────────────────

# URL base de la API que consume el frontend
# Local:      http://localhost:3000/api/v1
# Producción: https://tu-backend.railway.app/api/v1
VITE_API_URL=http://localhost:3000/api/v1