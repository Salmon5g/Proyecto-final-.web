        {
          "name": "Login — guarda token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.ok && res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('✅ Token guardado:', res.token.substring(0, 30) + '...');",
                  "} else {",
                  "    console.warn('⚠️ No se pudo capturar el token');",
                  "}",
                  "pm.test('Login exitoso - status 200', () => pm.response.to.have.status(200));",
